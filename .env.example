# ─────────────────────────────────────────────────────────────────────
# AtollDrift — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Public keys — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Private — server-only, never exposed to browser
# Used for admin operations (reading host applications, etc.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic (AI Journey Finder) ─────────────────────────────────────
# Find at: https://console.anthropic.com/
# Move the AI call to /api/journey-finder/route.ts and use this key server-side
ANTHROPIC_API_KEY=sk-ant-your-key-here
